              <tr>
                <th>Nama</th>
                <th>Kontak</th>
                <th>Platform</th>
                <th>Status</th>
                <th>Tanggal</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody id="leadTableBody"></tbody>
          </table>
        </div>
        <p id="leadEmpty" class="text-muted text-center" hidden>Belum ada lead.</p>
      </div>
    </section>

