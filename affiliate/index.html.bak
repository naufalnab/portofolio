<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CryptoSharia Affiliate Command Center</title>
  <meta name="description" content="Dashboard kerja pribadi affiliate content creator CryptoSharia Masterclass">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="style.css">
</head>

<body>
  <!-- Toast Notification -->
  <div id="toast" class="toast" aria-live="polite"></div>

  <!-- Confirm Modal -->
  <div id="confirmModal" class="modal-overlay" hidden>
    <div class="modal">
      <div class="modal-icon">⚠️</div>
      <h3 id="confirmTitle">Konfirmasi</h3>
      <p id="confirmMessage">Apakah Anda yakin?</p>
      <div class="modal-actions">
        <button id="confirmCancel" class="btn btn-ghost">Batal</button>
        <button id="confirmOk" class="btn btn-danger">Hapus</button>
      </div>
    </div>
  </div>

  <!-- Sidebar -->
  <aside id="sidebar" class="sidebar">
    <div class="sidebar-brand">
      <div class="brand-icon">
        <svg viewBox="0 0 40 40" width="40" height="40">
          <defs>
            <linearGradient id="brandGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" style="stop-color:#c9a84c" />
              <stop offset="100%" style="stop-color:#e8c66a" />
            </linearGradient>
          </defs>
          <rect width="40" height="40" rx="10" fill="url(#brandGrad)" />
          <text x="20" y="27" text-anchor="middle" fill="#0a1628" font-size="18" font-weight="800"
            font-family="Outfit">CS</text>
        </svg>
      </div>
      <div class="brand-text">
        <span class="brand-name">CryptoSharia</span>
        <span class="brand-sub">Command Center</span>
      </div>
    </div>
    <nav class="sidebar-nav">
      <a href="#dashboard" class="nav-link active" data-section="dashboard">
        <span class="nav-icon">📊</span><span class="nav-text">Dashboard</span>
      </a>
      <a href="#alur" class="nav-link" data-section="alur">
        <span class="nav-icon">🔄</span><span class="nav-text">Alur Affiliate</span>
      </a>
      <a href="#studio" class="nav-link" data-section="studio">
        <span class="nav-icon">🎬</span><span class="nav-text">Content Studio</span>
      </a>
      <a href="#promo" class="nav-link" data-section="promo">
        <span class="nav-icon">🏷️</span><span class="nav-text">Promo & WhatsApp</span>
      </a>
      <a href="#leads" class="nav-link" data-section="leads">
        <span class="nav-icon">👥</span><span class="nav-text">Lead Tracker</span>
      </a>
      <a href="#performance" class="nav-link" data-section="performance">
        <span class="nav-icon">📈</span><span class="nav-text">Content Performance</span>
      </a>
      <a href="#komisi" class="nav-link" data-section="komisi">
        <span class="nav-icon">💰</span><span class="nav-text">Komisi Calculator</span>
      </a>
      <a href="#calendar" class="nav-link" data-section="calendar">
        <span class="nav-icon">📅</span><span class="nav-text">Calendar & Checklist</span>
      </a>
      <a href="#assets" class="nav-link" data-section="assets">
        <span class="nav-icon">🎨</span><span class="nav-text">Asset Library</span>
      </a>
      <a href="#syariah" class="nav-link" data-section="syariah">
        <span class="nav-icon">📜</span><span class="nav-text">Prinsip Syariah</span>
      </a>
    </nav>
    <div class="sidebar-footer">
      <div class="quick-copy-section">
        <p class="quick-copy-title">⚡ Quick Copy</p>
        <button class="btn btn-sm btn-outline" onclick="App.quickCopy('cta')">Copy CTA</button>
        <button class="btn btn-sm btn-outline" onclick="App.quickCopy('admin')">Copy Pesan Admin</button>
        <button class="btn btn-sm btn-outline" onclick="App.quickCopy('followup')">Copy Follow Up</button>
        <button class="btn btn-sm btn-outline" onclick="App.quickCopy('caption')">Copy Caption</button>
        <button class="btn btn-sm btn-outline" onclick="App.quickCopy('disclaimer')">Copy Disclaimer</button>
      </div>
    </div>
  </aside>

  <!-- Mobile Header -->
  <header class="mobile-header">
    <button id="menuToggle" class="menu-toggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
    <span class="mobile-brand">CryptoSharia CC</span>
  </header>

  <!-- Main Content -->
  <main id="mainContent" class="main-content">

    <!-- ==================== SECTION 1: DASHBOARD ==================== -->
    <section id="dashboard" class="section active">
      <div class="section-header">
        <h1>Dashboard</h1>
        <p class="section-subtitle">Ringkasan performa affiliate Anda</p>
      </div>

      <!-- Promo Code Banner -->
      <div class="promo-banner" id="dashPromo">
        <div class="promo-banner-content">
          <span class="promo-label">Kode Promo Anda</span>
          <span class="promo-code" id="dashPromoCode">P - NFL</span>
          <button class="btn btn-gold btn-sm" onclick="App.copyPromoCode()">📋 Copy</button>
        </div>
      </div>

      <!-- Stats Grid -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon stat-icon-blue">👥</div>
          <div class="stat-info">
            <span class="stat-value" id="statTotalLeads">0</span>
            <span class="stat-label">Total Lead</span>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon stat-icon-purple">📤</div>
          <div class="stat-info">
            <span class="stat-value" id="statDirected">0</span>
            <span class="stat-label">Diarahkan ke Admin</span>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon stat-icon-green">✅</div>
          <div class="stat-info">
            <span class="stat-value" id="statRegistered">0</span>
            <span class="stat-label">Sudah Daftar</span>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon stat-icon-orange">🎬</div>
          <div class="stat-info">
            <span class="stat-value" id="statContent">0</span>
            <span class="stat-label">Konten Diposting</span>
          </div>
        </div>
        <div class="stat-card stat-card-highlight">
          <div class="stat-icon stat-icon-gold">💰</div>
          <div class="stat-info">
            <span class="stat-value" id="statKomisi">Rp0</span>
            <span class="stat-label">Estimasi Komisi</span>
          </div>
        </div>
      </div>

      <!-- Best Content & CTA -->
      <div class="grid-2">
        <div class="card">
          <h3 class="card-title">🏆 Konten Terbaik</h3>
          <div id="bestContent" class="best-item">
            <p class="text-muted">Belum ada data konten</p>
          </div>
        </div>
        <div class="card">
          <h3 class="card-title">🎯 CTA Terbaik</h3>
          <div id="bestCTA" class="best-item">
            <p class="text-muted">Belum ada data CTA</p>
          </div>
        </div>
      </div>

      <!-- Best Content Insights -->
      <div class="card">
        <h3 class="card-title">💡 Best Content Insights</h3>
        <div id="contentInsights" class="insights-container">
          <p class="text-muted">Insights akan muncul setelah ada data performa konten yang cukup.</p>
        </div>
      </div>

      <!-- Progress Target -->
      <div class="card">
        <h3 class="card-title">🎯 Progress Target Affiliate</h3>
        <div class="target-grid">
          <div class="target-card">
            <div class="target-header">
              <span class="target-name">Target 3 Pendaftar</span>
              <span class="target-badge badge-bronze">Bronze</span>
            </div>
            <div class="progress-bar">
              <div class="progress-fill" id="progress3" style="width:0%"></div>
            </div>
            <div class="target-footer">
              <span id="progress3Text">0/3</span>
              <span class="target-komisi">Potensi: Rp1.500.000</span>
            </div>
          </div>
          <div class="target-card">
            <div class="target-header">
              <span class="target-name">Target 5 Pendaftar</span>
              <span class="target-badge badge-silver">Silver</span>
            </div>
            <div class="progress-bar">
              <div class="progress-fill" id="progress5" style="width:0%"></div>
            </div>
            <div class="target-footer">
              <span id="progress5Text">0/5</span>
              <span class="target-komisi">Potensi: Rp3.000.000</span>
            </div>
          </div>
          <div class="target-card">
            <div class="target-header">
              <span class="target-name">Target 10 Pendaftar</span>
              <span class="target-badge badge-gold">Gold</span>
            </div>
            <div class="progress-bar">
              <div class="progress-fill" id="progress10" style="width:0%"></div>
            </div>
            <div class="target-footer">
              <span id="progress10Text">0/10</span>
              <span class="target-komisi">Potensi: Rp8.000.000</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Hook A/B Comparison -->
      <div class="card">
        <h3 class="card-title">🔬 Hook A/B Comparison</h3>
        <div class="ab-comparison">
          <div class="ab-side">
            <h4>Hook A</h4>
            <select id="hookASelect" class="input" onchange="App.updateABComparison()">
              <option value="">Pilih Hook A...</option>
            </select>
            <div class="ab-stats" id="hookAStats">
              <div class="ab-stat"><span class="ab-stat-label">Views</span><input type="number" id="hookAViews"
                  class="input input-sm" value="0" min="0"></div>
              <div class="ab-stat"><span class="ab-stat-label">DM</span><input type="number" id="hookADM"
                  class="input input-sm" value="0" min="0"></div>
              <div class="ab-stat"><span class="ab-stat-label">Lead</span><input type="number" id="hookALead"
                  class="input input-sm" value="0" min="0"></div>
              <div class="ab-stat"><span class="ab-stat-label">Pendaftar</span><input type="number" id="hookAReg"
                  class="input input-sm" value="0" min="0"></div>
            </div>
          </div>
          <div class="ab-vs">VS</div>
          <div class="ab-side">
            <h4>Hook B</h4>
            <select id="hookBSelect" class="input" onchange="App.updateABComparison()">
              <option value="">Pilih Hook B...</option>
            </select>
            <div class="ab-stats" id="hookBStats">
              <div class="ab-stat"><span class="ab-stat-label">Views</span><input type="number" id="hookBViews"
                  class="input input-sm" value="0" min="0"></div>
              <div class="ab-stat"><span class="ab-stat-label">DM</span><input type="number" id="hookBDM"
                  class="input input-sm" value="0" min="0"></div>
              <div class="ab-stat"><span class="ab-stat-label">Lead</span><input type="number" id="hookBLead"
                  class="input input-sm" value="0" min="0"></div>
              <div class="ab-stat"><span class="ab-stat-label">Pendaftar</span><input type="number" id="hookBReg"
                  class="input input-sm" value="0" min="0"></div>
            </div>
          </div>
        </div>
        <div class="ab-result" id="abResult">
          <p class="text-muted">Pilih dua hook dan isi data untuk melihat perbandingan.</p>
        </div>
        <div class="form-actions">
          <button class="btn btn-primary" onclick="App.saveABComparison()">💾 Simpan Perbandingan</button>
          <button class="btn btn-ghost" onclick="App.resetABComparison()">🔄 Reset</button>
        </div>
      </div>
    </section>

    <!-- ==================== SECTION 2: ALUR AFFILIATE ==================== -->
    <section id="alur" class="section">
      <div class="section-header">
        <h1>Bagaimana Affiliate Marketing Ini Bekerja</h1>
        <p class="section-subtitle">Pahami alur dari konten hingga komisi</p>
      </div>

      <!-- Flowchart Timeline -->
      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-dot">1</div>
          <div class="timeline-content">
            <h3>🎬 Membuat Konten</h3>
            <p>Anda membuat konten edukatif amigurumi 3D faceless tentang crypto syariah di TikTok, Instagram Reels,
              atau YouTube Shorts.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot">2</div>
          <div class="timeline-content">
            <h3>👀 Audiens Menonton</h3>
            <p>Audiens yang tertarik dengan edukasi crypto syariah menonton konten Anda dan mulai engage.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot">3</div>
          <div class="timeline-content">
            <h3>💬 Audiens DM / Chat / Klik CTA</h3>
            <p>Audiens menghubungi Anda melalui DM, komentar, atau mengikuti CTA di konten Anda.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot">4</div>
          <div class="timeline-content">
            <h3>📱 Mengarahkan ke WhatsApp Admin</h3>
            <p>Anda mengarahkan calon peserta untuk chat langsung dengan admin CryptoSharia via WhatsApp.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot">5</div>
          <div class="timeline-content">
            <h3>🏷️ Menyebutkan Kode Promo</h3>
            <p>Calon peserta menyebutkan kode promo Anda saat chat admin agar tercatat sebagai referral Anda.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot">6</div>
          <div class="timeline-content">
            <h3>📋 Admin Mencatat Kode Promo</h3>
            <p>Admin CryptoSharia memverifikasi dan mencatat kode promo yang digunakan calon peserta.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot">7</div>
          <div class="timeline-content">
            <h3>✅ Pendaftaran Valid Dihitung</h3>
            <p>Pendaftaran berbayar yang sah dihitung sebagai konversi affiliate Anda.</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot">8</div>
          <div class="timeline-content">
            <h3>💰 Komisi Dibayarkan</h3>
            <p>Komisi affiliate dibayarkan setelah periode pendaftaran Masterclass ditutup.</p>
          </div>
        </div>
      </div>

      <!-- Funnel -->
      <div class="card">
        <h3 class="card-title">📊 Funnel Affiliate</h3>
        <div class="funnel">
          <div class="funnel-step funnel-1">
            <span class="funnel-label">🎬 Konten</span>
          </div>
          <div class="funnel-arrow">▼</div>
          <div class="funnel-step funnel-2">
            <span class="funnel-label">💬 Interaksi</span>
          </div>
          <div class="funnel-arrow">▼</div>
          <div class="funnel-step funnel-3">
            <span class="funnel-label">👥 Lead</span>
          </div>
          <div class="funnel-arrow">▼</div>
          <div class="funnel-step funnel-4">
            <span class="funnel-label">📱 Chat Admin</span>
          </div>
          <div class="funnel-arrow">▼</div>
          <div class="funnel-step funnel-5">
            <span class="funnel-label">✅ Pendaftaran</span>
          </div>
          <div class="funnel-arrow">▼</div>
          <div class="funnel-step funnel-6">
            <span class="funnel-label">💰 Komisi</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== SECTION 3: CONTENT STUDIO ==================== -->
    <section id="studio" class="section">
      <div class="section-header">
        <h1>Content Studio</h1>
        <p class="section-subtitle">Buat, kelola, dan simpan semua konten Anda</p>
      </div>

      <!-- Tabs -->
      <div class="tab-bar">
        <button class="tab-btn active" data-tab="studioCreate">➕ Buat Konten</button>
        <button class="tab-btn" data-tab="studioList">📋 Daftar Konten</button>
        <button class="tab-btn" data-tab="studioBank">📚 Bank Konten</button>
      </div>

      <!-- Tab: Create Content -->
      <div id="studioCreate" class="tab-content active">
        <div class="card">
          <h3 class="card-title">Buat Konten Baru</h3>
          <form id="contentForm" class="form-grid">
            <input type="hidden" id="contentEditId" value="">
            <div class="form-group">
              <label for="contentTitle">Judul Konten</label>
              <input type="text" id="contentTitle" class="input" placeholder="Masukkan judul konten..." required>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="contentPlatform">Platform</label>
                <select id="contentPlatform" class="input">
                  <option value="TikTok">TikTok</option>
                  <option value="Instagram Reels">Instagram Reels</option>
                  <option value="YouTube Shorts">YouTube Shorts</option>
                </select>
              </div>
              <div class="form-group">
                <label for="contentCategory">Kategori</label>
                <select id="contentCategory" class="input">
                  <option value="edukasi">Edukasi</option>
                  <option value="anti-FOMO">Anti-FOMO</option>
                  <option value="syariah">Syariah</option>
                  <option value="pemula">Pemula</option>
                  <option value="soft selling">Soft Selling</option>
                  <option value="CTA">CTA</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label for="contentHook">Hook</label>
              <textarea id="contentHook" class="input" rows="2" placeholder="Hook pembuka konten..."></textarea>
            </div>
            <div class="form-group">
              <label for="contentScript">Isi Script</label>
              <textarea id="contentScript" class="input" rows="5"
                placeholder="Tulis script lengkap di sini..."></textarea>
            </div>
            <div class="form-group">
              <label for="contentCTA">CTA</label>
              <textarea id="contentCTA" class="input" rows="2" placeholder="Call to action..."></textarea>
            </div>
            <div class="form-group">
              <label for="contentCaption">Caption</label>
              <textarea id="contentCaption" class="input" rows="3" placeholder="Caption untuk posting..."></textarea>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="contentStatus">Status</label>
                <select id="contentStatus" class="input">
                  <option value="draft">Draft</option>
                  <option value="ready">Ready</option>
                  <option value="posted">Posted</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label for="contentNotes">Catatan</label>
              <textarea id="contentNotes" class="input" rows="2" placeholder="Catatan tambahan..."></textarea>
            </div>
            <div class="form-actions">
              <button type="submit" class="btn btn-primary">💾 Simpan Konten</button>
              <button type="button" class="btn btn-ghost" onclick="App.resetContentForm()">🔄 Reset</button>
            </div>
          </form>
        </div>
      </div>

      <!-- Tab: Content List -->
      <div id="studioList" class="tab-content">
        <div class="card">
          <div class="card-header-row">
            <h3 class="card-title">Daftar Konten</h3>
            <div class="card-actions">
              <input type="text" id="contentSearch" class="input input-sm" placeholder="🔍 Cari konten..."
                oninput="App.filterContent()">
              <button class="btn btn-sm btn-danger" onclick="App.resetModule('contents')">🗑️ Reset Data</button>
            </div>
          </div>
          <div class="table-wrap">
            <table class="table" id="contentTable">
              <thead>
                <tr>
                  <th>Judul</th>
                  <th>Platform</th>
                  <th>Kategori</th>
                  <th>Status</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody id="contentTableBody"></tbody>
            </table>
          </div>
          <p id="contentEmpty" class="text-muted text-center" hidden>Belum ada konten tersimpan.</p>
        </div>
      </div>

      <!-- Tab: Content Bank -->
      <div id="studioBank" class="tab-content">
        <div class="grid-2">
          <!-- Ideas Bank -->
          <div class="card">
            <h3 class="card-title">💡 Bank Ide Konten</h3>
            <div class="bank-list" id="ideaBank"></div>
          </div>
          <!-- Hook Bank -->
          <div class="card">
            <h3 class="card-title">🎣 Bank Hook</h3>
            <div class="bank-list" id="hookBank"></div>
          </div>
          <!-- CTA Bank -->
          <div class="card">
            <h3 class="card-title">🎯 Bank CTA</h3>
            <div class="bank-list" id="ctaBank"></div>
          </div>
          <!-- Script Bank -->
          <div class="card">
            <h3 class="card-title">📝 Bank Script Pendek (30–60 detik)</h3>
            <div class="bank-list" id="scriptBank"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== SECTION 4: PROMO & WHATSAPP ==================== -->
    <section id="promo" class="section">
      <div class="section-header">
        <h1>Promo Code & WhatsApp Tools</h1>
        <p class="section-subtitle">Pusat alat promosi dan komunikasi</p>
      </div>

      <div class="grid-2">
        <!-- Promo Code Card -->
        <div class="card promo-card-big">
          <div class="promo-display">
            <span class="promo-label-big">KODE PROMO ANDA</span>
            <span class="promo-code-big" id="promoCodeDisplay">P - NFL</span>
            <button class="btn btn-gold" onclick="App.copyPromoCode()">📋 Copy Kode Promo</button>
          </div>
          <div class="promo-benefits">
            <h4>Benefit untuk Calon Peserta:</h4>
            <ul>
              <li>✅ Diskon tambahan <strong>Rp250.000</strong></li>
              <li>✅ Bonus member <strong>Discord Premium 6 bulan</strong> (setara Rp1.000.000)</li>
            </ul>
          </div>
          <div class="promo-format">
            <h4>Format Kode Promo</h4>
            <p><strong>M</strong> = Member CryptoSharia<br>
              <strong>P</strong> = Pengurus CryptoSharia<br>
              + Inisial nama + Nomor urut
            </p>
            <p class="text-muted text-sm">Contoh: P - NFL | Kode final diberikan admin.</p>
          </div>
          <!-- Promo Code Simulator -->
          <div class="promo-simulator">
            <h4>Simulasi Format Kode</h4>
            <div class="form-row">
              <div class="form-group">
                <label for="promoType">Tipe</label>
                <select id="promoType" class="input" onchange="App.simulatePromo()">
                  <option value="M">M (Member)</option>
                  <option value="P">P (Pengurus)</option>
                </select>
              </div>
              <div class="form-group">
                <label for="promoInitial">Inisial</label>
                <input type="text" id="promoInitial" class="input" maxlength="3" placeholder="SA"
                  oninput="App.simulatePromo()">
              </div>
              <div class="form-group">
                <label for="promoNumber">Nomor</label>
                <input type="text" id="promoNumber" class="input" maxlength="3" placeholder="01"
                  oninput="App.simulatePromo()">
              </div>
            </div>
            <div class="promo-preview">
              <span>Hasil: </span><strong id="promoSimResult">P - NFL</strong>
            </div>
          </div>
        </div>

        <!-- WhatsApp Message Generator -->
        <div class="card">
          <h3 class="card-title">📱 WhatsApp Message Generator</h3>
          <div class="form-group">
            <label for="waAdminNumber">Nomor WhatsApp Admin</label>
            <input type="tel" id="waAdminNumber" class="input" placeholder="628xxxxxxxxxx">
          </div>
          <div class="form-group">
            <label for="waName">Nama Calon Peserta (opsional)</label>
            <input type="text" id="waName" class="input" placeholder="Nama...">
          </div>
          <div class="form-group">
            <label>Preview Pesan:</label>
            <div class="wa-preview" id="waPreview">
              Assalamu'alaikum Admin CryptoSharia, saya ingin daftar CryptoSharia Masterclass menggunakan kode promo:
              <strong>P - NFL</strong>.
            </div>
          </div>
          <div class="form-actions">
            <button class="btn btn-green" onclick="App.openWhatsApp()">📱 Buka WhatsApp</button>
            <button class="btn btn-outline" onclick="App.copyWAMessage()">📋 Copy Pesan</button>
          </div>
        </div>
      </div>

      <!-- Message Templates -->
      <div class="card">
        <h3 class="card-title">📨 Template Pesan</h3>
        <div class="template-grid" id="templateGrid"></div>
      </div>
    </section>

    <!-- ==================== SECTION 5: LEAD TRACKER ==================== -->
    <section id="leads" class="section">
      <div class="section-header">
        <h1>Lead Tracker</h1>
        <p class="section-subtitle">Lacak dan kelola semua lead Anda</p>
      </div>

      <!-- Lead Stats -->
      <div class="stats-grid stats-grid-sm">
        <div class="stat-card">
          <div class="stat-info">
            <span class="stat-value" id="leadTotal">0</span>
            <span class="stat-label">Total Lead</span>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-info">
            <span class="stat-value" id="leadDirected">0</span>
            <span class="stat-label">Diarahkan ke Admin</span>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-info">
            <span class="stat-value" id="leadRegistered">0</span>
            <span class="stat-label">Sudah Daftar</span>
          </div>
        </div>
      </div>

      <!-- Lead Form -->
      <div class="card">
        <h3 class="card-title">➕ Tambah Lead</h3>
        <form id="leadForm" class="form-grid">
          <input type="hidden" id="leadEditId" value="">
          <div class="form-row">
            <div class="form-group">
              <label for="leadName">Nama Lead</label>
              <input type="text" id="leadName" class="input" placeholder="Nama..." required>
            </div>
            <div class="form-group">
              <label for="leadContact">Kontak / Username</label>
              <input type="text" id="leadContact" class="input" placeholder="@username atau nomor HP">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="leadPlatform">Sumber Platform</label>
              <select id="leadPlatform" class="input">
                <option value="TikTok">TikTok</option>
                <option value="Instagram">Instagram</option>
                <option value="YouTube Shorts">YouTube Shorts</option>
                <option value="WhatsApp">WhatsApp</option>
                <option value="Story">Story</option>
                <option value="Lainnya">Lainnya</option>
              </select>
            </div>
            <div class="form-group">
              <label for="leadSource">Konten / Hook Asal</label>
              <input type="text" id="leadSource" class="input" placeholder="Judul konten atau hook...">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="leadStatus">Status</label>
              <select id="leadStatus" class="input">
                <option value="baru masuk">Baru Masuk</option>
                <option value="tanya-tanya">Tanya-tanya</option>
                <option value="sudah dikirim info">Sudah Dikirim Info</option>
                <option value="sudah diarahkan ke admin">Sudah Diarahkan ke Admin</option>
                <option value="sudah chat admin">Sudah Chat Admin</option>
                <option value="sudah daftar">Sudah Daftar</option>
                <option value="belum jadi">Belum Jadi</option>
                <option value="follow up nanti">Follow Up Nanti</option>
              </select>
            </div>
            <div class="form-group">
              <label for="leadDate">Tanggal Masuk</label>
              <input type="date" id="leadDate" class="input">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="leadFollowUp">Follow Up Date</label>
              <input type="date" id="leadFollowUp" class="input">
            </div>
          </div>
          <div class="form-group">
            <label for="leadNotes">Catatan</label>
            <textarea id="leadNotes" class="input" rows="2" placeholder="Catatan..."></textarea>
          </div>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary">💾 Simpan Lead</button>
            <button type="button" class="btn btn-ghost" onclick="App.resetLeadForm()">🔄 Reset</button>
          </div>
        </form>
      </div>

      <!-- Lead Table -->
      <div class="card">
        <div class="card-header-row">
          <h3 class="card-title">📋 Daftar Lead</h3>
          <div class="card-actions">
            <input type="text" id="leadSearch" class="input input-sm" placeholder="🔍 Cari lead..."
              oninput="App.filterLeads()">
            <select id="leadFilter" class="input input-sm" onchange="App.filterLeads()">
              <option value="">Semua Status</option>
              <option value="baru masuk">Baru Masuk</option>
              <option value="tanya-tanya">Tanya-tanya</option>
              <option value="sudah dikirim info">Sudah Dikirim Info</option>
              <option value="sudah diarahkan ke admin">Sudah Diarahkan ke Admin</option>
              <option value="sudah chat admin">Sudah Chat Admin</option>
              <option value="sudah daftar">Sudah Daftar</option>
              <option value="belum jadi">Belum Jadi</option>
              <option value="follow up nanti">Follow Up Nanti</option>
            </select>
            <button class="btn btn-sm btn-outline" onclick="App.exportLeadsCSV()">📥 Export CSV</button>
            <button class="btn btn-sm btn-danger" onclick="App.resetModule('leads')">🗑️ Reset Data</button>
          </div>
        </div>
        <div class="table-wrap">
          <table class="table" id="leadTable">
