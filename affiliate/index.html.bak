              <input type="checkbox" data-check="hook" onchange="App.saveChecklist()">
              <span class="checkmark"></span>
              <span>Sudah buat 1 hook</span>
            </label>
            <label class="checklist-item">
              <input type="checkbox" data-check="script" onchange="App.saveChecklist()">
              <span class="checkmark"></span>
              <span>Sudah siapkan 1 script</span>
            </label>
            <label class="checklist-item">
              <input type="checkbox" data-check="posting" onchange="App.saveChecklist()">
              <span class="checkmark"></span>
              <span>Sudah posting 1 konten</span>
            </label>
            <label class="checklist-item">
              <input type="checkbox" data-check="story" onchange="App.saveChecklist()">
              <span class="checkmark"></span>
              <span>Sudah upload story CTA</span>
            </label>
            <label class="checklist-item">
              <input type="checkbox" data-check="followup" onchange="App.saveChecklist()">
              <span class="checkmark"></span>
              <span>Sudah follow up lead</span>
            </label>
            <label class="checklist-item">
