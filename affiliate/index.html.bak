              <input type="text" id="calTheme" class="input" placeholder="Tema konten...">
            </div>
            <div class="form-group">
              <label for="calTitle">Judul Konten</label>
              <input type="text" id="calTitle" class="input" placeholder="Judul konten..." required>
            </div>
            <div class="form-group">
              <label for="calCTA">CTA</label>
              <input type="text" id="calCTA" class="input" placeholder="Call to action...">
            </div>
            <div class="form-group">
              <label for="calStatus">Status Produksi</label>
              <select id="calStatus" class="input">
                <option value="ide">💡 Ide</option>
                <option value="script">📝 Script</option>
                <option value="ready">✅ Ready</option>
