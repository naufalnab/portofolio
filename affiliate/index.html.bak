    <!-- ==================== SECTION 7: KOMISI CALCULATOR ==================== -->
    <section id="komisi" class="section">
      <div class="section-header">
        <h1>Komisi Calculator</h1>
        <p class="section-subtitle">Hitung estimasi komisi affiliate Anda</p>
      </div>

      <div class="grid-2">
        <div class="card">
          <h3 class="card-title">🧮 Kalkulator</h3>
          <div class="form-group">
            <label for="komisiInput">Jumlah Pendaftar Valid</label>
            <input type="number" id="komisiInput" class="input input-lg" min="0" value="0"
              oninput="App.calculateKomisi()">
          </div>
          <div class="komisi-breakdown" id="komisiBreakdown">
            <div class="komisi-row">
              <span>1–3 pendaftar × Rp500.000</span>
              <span id="komisi1">Rp0</span>
            </div>
            <div class="komisi-row">
              <span>4–5 pendaftar × Rp750.000</span>
              <span id="komisi2">Rp0</span>
            </div>
            <div class="komisi-row">
              <span>6+ pendaftar × Rp1.000.000</span>
              <span id="komisi3">Rp0</span>
            </div>
            <div class="komisi-total">
              <span>Total Estimasi Komisi</span>
              <span id="komisiTotal">Rp0</span>
            </div>
          </div>
          <p class="text-muted text-sm">⚠️ Komisi final mengikuti validasi admin dan hanya dihitung dari pendaftaran
            berbayar yang sah.</p>
        </div>

        <div class="card">
          <h3 class="card-title">📋 Contoh Perhitungan</h3>
          <div class="komisi-examples">
            <div class="komisi-example" onclick="App.setKomisiExample(3)">
              <h4>3 Pendaftar</h4>
              <p class="komisi-amount">Rp1.500.000</p>
              <p class="text-sm">3 × Rp500.000</p>
            </div>
            <div class="komisi-example" onclick="App.setKomisiExample(5)">
              <h4>5 Pendaftar</h4>
              <p class="komisi-amount">Rp3.000.000</p>
              <p class="text-sm">3×500rb + 2×750rb</p>
            </div>
            <div class="komisi-example" onclick="App.setKomisiExample(10)">
              <h4>10 Pendaftar</h4>
              <p class="komisi-amount">Rp8.000.000</p>
              <p class="text-sm">3×500rb + 2×750rb + 5×1jt</p>
            </div>
          </div>

          <div class="komisi-tiers">
            <h4>Skema Komisi</h4>
            <table class="table table-sm">
              <thead>
                <tr>
                  <th>Pendaftar</th>
                  <th>Komisi/Orang</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Ke-1 s/d ke-3</td>
                  <td>Rp500.000</td>
                </tr>
                <tr>
                  <td>Ke-4 dan ke-5</td>
                  <td>Rp750.000</td>
                </tr>
                <tr>
                  <td>Ke-6 dan seterusnya</td>
                  <td>Rp1.000.000</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== SECTION 8: CALENDAR ==================== -->
    <section id="calendar" class="section">
      <div class="section-header">
        <h1>Content Calendar & Checklist</h1>
        <p class="section-subtitle">Rencanakan dan pantau aktivitas harian Anda</p>
      </div>

      <div class="grid-2">
        <!-- Calendar -->
        <div class="card">
          <h3 class="card-title">📅 Rencana Konten</h3>
          <form id="calendarForm" class="form-grid">
            <input type="hidden" id="calEditId" value="">
            <div class="form-row">
              <div class="form-group">
                <label for="calDate">Tanggal</label>
                <input type="date" id="calDate" class="input" required>
              </div>
              <div class="form-group">
                <label for="calPlatform">Platform</label>
                <select id="calPlatform" class="input">
                  <option value="TikTok">TikTok</option>
                  <option value="Instagram Reels">Instagram Reels</option>
