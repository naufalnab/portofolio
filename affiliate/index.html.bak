          <div class="form-actions" style="margin-top: var(--space-3);">
            <button class="btn btn-sm btn-danger" onclick="App.resetModule('calendar')">🗑️ Reset Data</button>
          </div>
        </div>

        <!-- Daily Checklist -->
        <div class="card">
          <h3 class="card-title">✅ Checklist Harian</h3>
          <div class="checklist-date">
            <input type="date" id="checklistDate" class="input" onchange="App.loadChecklist()">
          </div>
