              <span>Sudah cek performa konten</span>
            </label>
            <label class="checklist-item">
              <input type="checkbox" data-check="arahkan" onchange="App.saveChecklist()">
              <span class="checkmark"></span>
              <span>Sudah arahkan lead ke admin</span>
            </label>
          </div>
          <div class="checklist-progress">
            <div class="progress-bar">
              <div class="progress-fill progress-fill-green" id="checklistProgress" style="width:0%"></div>
            </div>
            <span id="checklistProgressText" class="text-sm">0/7 selesai</span>
          </div>

          <!-- Weekly Progress -->
